# .env.example — commit this one, never commit .env
PORT=5000
NODE_ENV=development

# Neon connection string (get this after Step 4 below)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Groq
GROQ_API_KEY=

# Chroma Cloud
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# Auth (used starting Step 2)
JWT_SECRET=
JWT_EXPIRES_IN=